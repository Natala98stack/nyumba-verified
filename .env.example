# --- Front-end (browser) vars: safe to expose, must start with VITE_ ---
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- Server-only vars: set these in Vercel > Settings > Environment Variables ---
# Do NOT put these in this file or commit them. They power /api functions.
# RESEND_API_KEY=re_xxx
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ... (Supabase > Settings > API > service_role)
# ANTHROPIC_API_KEY=sk-ant-xxx        (optional — enables ID auto-scan)
# ADMIN_EMAIL=you@example.com          (optional — where fraud alerts go)
# FROM_EMAIL=NyumbaVerified <onboarding@resend.dev>
